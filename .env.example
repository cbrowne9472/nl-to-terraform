# LLM
OPENAI_API_KEY=sk-...

# LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=nl-to-terraform

# AWS (for Pricing API + deployment). Credentials come from the default
# boto3 chain (~/.aws/credentials or IAM role) - do not set AWS keys here,
# or they will shadow ~/.aws/credentials.
AWS_DEFAULT_REGION=us-east-1

# App
BACKEND_URL=http://localhost:8000
MAX_TERRAFORM_RESOURCES=20
MAX_MONTHLY_COST_USD=500
TERRAFORM_WORKSPACE_DIR=./backend/terraform/workspace
