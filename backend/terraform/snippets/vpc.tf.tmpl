resource "aws_vpc" "{name}" {{
  cidr_block           = "{cidr_block}"
  enable_dns_hostnames = true
  enable_dns_support   = true
  tags = {{ Name = "{project_name}-vpc" }}
}}

resource "aws_subnet" "{name}_az1" {{
  vpc_id            = aws_vpc.{name}.id
  cidr_block        = "{subnet_cidr_az1}"
  availability_zone = "{region}a"
  map_public_ip_on_launch = true
  tags = {{ Name = "{project_name}-subnet-az1" }}
}}

resource "aws_subnet" "{name}_az2" {{
  vpc_id            = aws_vpc.{name}.id
  cidr_block        = "{subnet_cidr_az2}"
  availability_zone = "{region}b"
  map_public_ip_on_launch = true
  tags = {{ Name = "{project_name}-subnet-az2" }}
}}

resource "aws_internet_gateway" "{name}_igw" {{
  vpc_id = aws_vpc.{name}.id
  tags = {{ Name = "{project_name}-igw" }}
}}

resource "aws_route_table" "{name}_public" {{
  vpc_id = aws_vpc.{name}.id
  route {{
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.{name}_igw.id
  }}
}}

resource "aws_route_table_association" "az1" {{
  subnet_id      = aws_subnet.{name}_az1.id
  route_table_id = aws_route_table.{name}_public.id
}}

resource "aws_route_table_association" "az2" {{
  subnet_id      = aws_subnet.{name}_az2.id
  route_table_id = aws_route_table.{name}_public.id
}}
