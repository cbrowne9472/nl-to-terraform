resource "aws_instance" "{name}" {{
  ami                    = "{ami_id}"
  instance_type          = "{instance_type}"
  subnet_id              = aws_subnet.{vpc_name}_az1.id
  vpc_security_group_ids = [aws_security_group.{sg_name}_app.id]

  root_block_device {{
    encrypted = {encrypted}
  }}

  tags = {{
    Name        = "{project_name}-instance"
    Project     = "{project_name}"
    Environment = "{environment}"
    ManagedBy   = "terraform"
  }}
}}
