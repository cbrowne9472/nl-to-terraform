resource "aws_lb" "{name}" {{
  name               = "{project_name}-alb"
  internal           = false
  load_balancer_type = "application"
  security_groups    = [aws_security_group.{sg_name}_alb.id]
  subnets            = [aws_subnet.{vpc_name}_az1.id, aws_subnet.{vpc_name}_az2.id]

  tags = {{
    Name        = "{project_name}-alb"
    Project     = "{project_name}"
    Environment = "{environment}"
    ManagedBy   = "terraform"
  }}
}}

resource "aws_lb_target_group" "{name}" {{
  name     = "{project_name}-tg"
  port     = {app_port}
  protocol = "HTTP"
  vpc_id   = aws_vpc.{vpc_name}.id

  health_check {{
    path                = "/"
    healthy_threshold   = 2
    unhealthy_threshold = 2
    timeout             = 5
    interval            = 30
  }}

  tags = {{ Name = "{project_name}-tg" }}
}}

resource "aws_lb_listener" "{name}" {{
  load_balancer_arn = aws_lb.{name}.arn
  port              = 80
  protocol          = "HTTP"

  default_action {{
    type             = "forward"
    target_group_arn = aws_lb_target_group.{name}.arn
  }}
}}
